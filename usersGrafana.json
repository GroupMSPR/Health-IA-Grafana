      "targets": [
        {
          "dataset": "laravel",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  CASE\r\n    WHEN EXTRACT(YEAR FROM age(birthdate)) < 18 THEN '<18'\r\n    WHEN EXTRACT(YEAR FROM age(birthdate)) BETWEEN 18 AND 24 THEN '18-24'\r\n    WHEN EXTRACT(YEAR FROM age(birthdate)) BETWEEN 25 AND 34 THEN '25-34'\r\n    WHEN EXTRACT(YEAR FROM age(birthdate)) BETWEEN 35 AND 44 THEN '35-44'\r\n    WHEN EXTRACT(YEAR FROM age(birthdate)) BETWEEN 45 AND 54 THEN '45-54'\r\n    WHEN EXTRACT(YEAR FROM age(birthdate)) BETWEEN 55 AND 64 THEN '55-64'\r\n    ELSE '65+'\r\n  END AS age_group,\r\n  COUNT(*) AS total_users\r\nFROM users\r\nWHERE birthdate IS NOT NULL\r\nGROUP BY age_group\r\nORDER BY age_group;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
