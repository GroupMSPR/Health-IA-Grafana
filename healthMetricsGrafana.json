        {
          "dataset": "laravel",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(100.0 * SUM(\r\n      CASE WHEN\r\n        (steps_count < 0)\r\n        OR (current_weight <= 0)\r\n        OR (avg_bpm < 30 OR avg_bpm > 220)\r\n        OR (max_bpm < 30 OR max_bpm > 250)\r\n        OR (active_minute < 0 OR active_minute > 1440)\r\n        OR (calories_burned < 0)\r\n      THEN 1 ELSE 0 END\r\n    ) / NULLIF(COUNT(*),0),\r\n    2\r\n  ) AS value\r\nFROM health_metrics;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
